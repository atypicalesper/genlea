{
  "name": "genlea",
  "version": "0.1.0",
  "description": "B2B Lead Generation Engine — US tech companies with Indian dev ratio",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run workers:dev\" \"npm run api:dev\"",
    "workers": "tsx src/workers/index.ts",
    "workers:dev": "tsx watch src/workers/index.ts",
    "api": "tsx src/api/server.ts",
    "api:dev": "tsx watch src/api/server.ts",
    "scrape": "tsx src/index.ts scrape",
    "score": "tsx src/index.ts score",
    "export": "tsx src/index.ts export",
    "stats": "tsx src/index.ts stats",
    "login": "tsx src/index.ts login",
    "db:init": "tsx scripts/db-init.ts",
    "seed": "tsx scripts/seed-queries.ts",
    "seed:10": "tsx scripts/seed-queries.ts 10",
    "seed:50": "tsx scripts/seed-queries.ts 50",
    "seed:100": "tsx scripts/seed-queries.ts 100",
    "verify-emails": "tsx scripts/verify-emails.ts",
    "rescore-all": "tsx scripts/rescore-all.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@bull-board/api": "^5.23.0",
    "@bull-board/fastify": "^5.23.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "axios": "^1.7.2",
    "bullmq": "^5.7.0",
    "commander": "^12.1.0",
    "csv-stringify": "^6.5.0",
    "dotenv-flow": "^4.1.0",
    "fast-levenshtein": "^3.0.0",
    "fastify": "^4.26.2",
    "groq-sdk": "^1.1.2",
    "ioredis": "^5.3.2",
    "mongodb": "^6.7.0",
    "mongoose": "^8.4.0",
    "node-cron": "^3.0.3",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "playwright": "^1.44.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.5.0",
    "tsx": "^4.15.6",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
