# ═══════════════════════════════════════════
#  GENLEA — Environment Variables Reference
# ═══════════════════════════════════════════
# Copy to .env and fill in values.
# DO NOT COMMIT .env to git.

# ─── MongoDB ────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=genlea

# ─── Redis (BullMQ) ─────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── Proxy Configuration ────────────────────
# Provider: brightdata | oxylabs | smartproxy | none
PROXY_PROVIDER=brightdata
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
BRIGHTDATA_ZONE=residential_rotating
# Or provide a plain text file, one proxy per line: host:port:user:pass
PROXY_LIST_FILE=proxies/proxy-list.txt

# ─── LinkedIn / Sales Navigator ─────────────
LI_SESSION_DIR=sessions/linkedin
# Fallback login credentials (if cookie session expires)
LI_USERNAME=
LI_PASSWORD=
# Sales Navigator account
SALESNAV_USERNAME=
SALESNAV_PASSWORD=

# ─── ZoomInfo ───────────────────────────────
ZOOMINFO_USERNAME=
ZOOMINFO_PASSWORD=

# ─── Crunchbase API ─────────────────────────
CRUNCHBASE_API_KEY=

# ─── Apollo.io API ──────────────────────────
APOLLO_API_KEY=

# ─── Hunter.io API ──────────────────────────
HUNTER_API_KEY=

# ─── Clearbit API ───────────────────────────
CLEARBIT_API_KEY=

# ─── GitHub API ─────────────────────────────
GITHUB_TOKEN=

# ─── Email Verification ─────────────────────
# Provider: mailcheck | custom-smtp | both
EMAIL_VERIFY_PROVIDER=mailcheck
MAILCHECK_API_KEY=

# ─── Agent Failure Alerts ─────────────────────────────────────────────────────
# Email sent when a discovery or enrichment agent throws an unhandled error.
# Leave ALERT_EMAIL_TO empty to disable (failures are logged at warn level).
# Works with any SMTP provider (Gmail app password, SendGrid SMTP, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=

# ─── Scraping Behaviour ─────────────────────
MAX_CONCURRENT_BROWSERS=3
SCRAPE_DELAY_MIN_MS=2000
SCRAPE_DELAY_MAX_MS=8000
# Max LinkedIn profiles per session per day
LI_MAX_PROFILES_PER_SESSION=80
# Session cooldown in hours after hitting limit
LI_SESSION_COOLDOWN_HOURS=8

# ─── Lead Filtering ─────────────────────────
# Strict: 0.75 | Tolerance (wider dataset): 0.60
INDIAN_RATIO_THRESHOLD=0.60
# Min employees visible on LinkedIn to compute ratio
INDIAN_RATIO_MIN_SAMPLE=10
# Score threshold for HOT lead
LEAD_SCORE_HOT_THRESHOLD=65
# Score threshold for WARM lead
LEAD_SCORE_WARM_THRESHOLD=50

# ─── Target Tech Stack Tags (comma-separated) ─
TARGET_TECH_STACK=nodejs,typescript,python,react,nextjs,nestjs,frontend,backend,fullstack,ai,ml,generative-ai,fastapi

# ─── LLM Provider ───────────────────────────
# ollama    → local, free, no limits (recommended)
#             setup: brew install ollama && ollama pull qwen3.5 && ollama serve
# groq      → cloud free tier, 500k TPD, resets daily
# anthropic → cloud paid, needs: npm install @anthropic-ai/sdk
AGENT_LLM_PROVIDER=ollama
AGENT_LLM_MODEL=qwen3.5
# OLLAMA_BASE_URL=http://localhost:11434
GROQ_API_KEY=
# ANTHROPIC_API_KEY=sk-ant-...

# ─── API Server ─────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
API_SECRET=change_me_before_production

# ─── Logging ────────────────────────────────
# Level: trace | debug | info | warn | error
LOG_LEVEL=info
LOG_PRETTY=true

# ─── Name Origin Analysis ────────────────────
# If using Python ethnicolr microservice:
ETHNICOLR_URL=http://localhost:5050
# Or use npm package: name-to-nationality
NAME_ORIGIN_PROVIDER=ethnicolr
